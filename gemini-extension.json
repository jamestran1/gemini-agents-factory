{
  "name": "gemini-agents-factory",
  "version": "1.1.2",
  "description": "An autonomous, multi-agent software development factory for the Gemini CLI.",
  "contextFileName": "GEMINI.md",
  "mcpServers": {
    "factory": {
      "command": "node",
      "args": [
        "${extensionPath}${/}src${/}mcp_server.js"
      ],
      "cwd": "${extensionPath}"
    }
  },
  "settings": [
    {
      "name": "Trello API Key",
      "envVar": "TRELLO_API_KEY",
      "sensitive": true
    },
    {
      "name": "Trello Token",
      "envVar": "TRELLO_TOKEN",
      "sensitive": true
    }
  ]
}
